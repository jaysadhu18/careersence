generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  name      String?
  phone     String?
  role      String?    // student, recent_graduate, career_switcher, other
  interests String?    // JSON array of selected interests
  isAdmin   Boolean    @default(false) // legacy field – kept to avoid data loss
  disabled  Boolean    @default(false) // admin can disable / re-enable
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  roadmaps     Roadmap[]
  savedJobs    SavedJob[]
  quizSessions QuizSession[]
  careerTrees  CareerTree[]
  resumeAnalyses ResumeAnalysis[]
  savedResources SavedResource[]
  internalResources InternalResource[]
  organizationName String? // For institute/university Resource Providers
}

model Roadmap {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  careerGoal String
  stages     String   // JSON array of stages
  createdAt  DateTime @default(now())
}

model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String   // external job ID from JSearch
  title     String
  company   String
  location  String
  url       String
  source    String   @default("jsearch")
  status    String   @default("saved") // saved | applied | interviewing | offer | rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, jobId])
}

model QuizSession {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phase1Answers   String   // JSON: answers to the 5 basic questions
  phase2Questions String?  // JSON: AI-generated follow-up questions
  phase2Answers   String?  // JSON: answers to follow-up questions
  results         String?  // JSON: AI-generated career recommendations
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CareerTree {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rootTitle   String                      // e.g. "Tech Career"
  formInput   String                      // JSON: skills, passions, currentStage, goals
  treeData    String                      // JSON: full CareerTreeData (root + branches)
  createdAt   DateTime @default(now())
}

model ResumeAnalysis {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName        String
  overallScore    Int
  subScores       String   // JSON: { impact, skills, formatting }
  markdownReport  String
  createdAt       DateTime @default(now())
}

model SavedResource {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resourceId      String   // external API ID (e.g. yt-xc34X, doc-552)
  title           String
  description     String   // store a snippet
  url             String
  type            String   // course, video, article, bootcamp
  source          String   // e.g. "YouTube", "Coursera"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, resourceId])
}

model InternalResource {
  id              String   @id @default(cuid())
  title           String
  description     String?
  resourceType    String   // "video", "article", "course"
  submittedById   String
  submittedBy     User     @relation(fields: [submittedById], references: [id], onDelete: Cascade)
  status          String   @default("pending") // "pending", "approved", "rejected"
  
  // Video specific
  videoFilePath   String?
  thumbnailPath   String?
  durationSeconds Int?
  resolution      String?
  language        String?

  // Article specific
  articleContent  String?  @db.Text
  summary         String?
  readTimeMinutes Int?
  tags            String?  // JSON array

  // Course specific
  courseTitle     String?
  courseDescription String?
  modules         String?  // JSON array
  totalDuration   Int?
  level           String?
  certificateAvailable Boolean? @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
